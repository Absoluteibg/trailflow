# Trailflow Environment Variables
# Copy this file to .env and fill in your values

# Ollama Configuration
# Base URL for Ollama API (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for LLM inference
# Format: model_name:tag or ollama/model_name:tag
# Default: qwen3:1.7b (change to your installed model)
OLLAMA_MODEL=qwen3:1.7b

# Telegram Bot Configuration (optional)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram user IDs
# Find your ID via @userinfobot on Telegram
ALLOWED_TELEGRAM_USER_IDS=

# Gemini API Key (optional - for future multi-provider support)
GEMINI_API_KEY=

# Application Configuration
# Public URL of the application (optional)
APP_URL=http://localhost:3000

# Workspace directory for agent file operations (default: ./workspace)
WORKSPACE_DIR=./workspace

# Logging Configuration
# One of: info, debug, error (default: info)
LOG_LEVEL=info

# API Authentication (optional but recommended for production)
# Set this to protect your web API endpoints
API_KEY=

# Agent task wall-clock timeout in milliseconds (default: 300000 = 5 minutes)
# Increase for complex long-running tasks, decrease for faster failure detection
AGENT_TIMEOUT_MS=300000
